{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install / update dependencies",
      "type": "shell",
      "command": "python bootstrap.py",
      "options": {
        "env": { "VS_QUEUE_MONITOR_SKIP_RUN": "1" }
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Install dev + test dependencies",
      "type": "shell",
      "command": ".venv/Scripts/pip install -r requirements-dev.txt && .venv/Scripts/playwright install chromium",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "dependsOn": "Install / update dependencies",
      "problemMatcher": []
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": ".venv/Scripts/python -m pytest tests/ -v",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
